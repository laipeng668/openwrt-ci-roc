### =========================
### IPQ60XX.nowifi.config（目标/机型 + NOWIFI）
### 配合 General.config 使用：cat General.config + 本文件 -> .config -> make defconfig
### =========================

#### Target：qualcommax / ipq60xx ####
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 只编译一个机型（关键）
# CONFIG_TARGET_MULTI_PROFILE is not set

# 只选择 360v6
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y

#### 平台相关（保留你之前常用的）####
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_11_4=y

#### =========================
#### NOWIFI：彻底禁用 WiFi userspace + 默认包 + 驱动/固件
#### 目标：只要有线，避免 hostapd/wpad 进入编译链
#### =========================

# 不需要 11ax/11ac userspace/驱动编译开关
# CONFIG_DRIVER_11AX_SUPPORT is not set
# CONFIG_DRIVER_11AC_SUPPORT is not set
# CONFIG_WPA_ENABLE_IEEE80211AX is not set
# CONFIG_WPA_ENABLE_IEEE80211AC is not set
# CONFIG_WPA_ENABLE_IEEE80211BE is not set

# 禁用 hostapd / wpa_supplicant / wpad 全部变体
# CONFIG_PACKAGE_hostapd-common is not set
# CONFIG_PACKAGE_wpa-supplicant is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-openssl is not set
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_wpad-full-openssl is not set

# 禁用 WiFi 辅助包
# CONFIG_PACKAGE_wifi-scripts is not set
# CONFIG_PACKAGE_wireless-regdb is not set
# CONFIG_PACKAGE_iw is not set

# 关键：把“默认包”也禁掉（否则 make defconfig 可能会选回来）
# CONFIG_DEFAULT_hostapd-common is not set
# CONFIG_DEFAULT_wifi-scripts is not set
# CONFIG_DEFAULT_wireless-regdb is not set
# CONFIG_DEFAULT_wpad-basic-mbedtls is not set
# CONFIG_DEFAULT_wpad-mbedtls is not set
# CONFIG_DEFAULT_wpad-basic-openssl is not set
# CONFIG_DEFAULT_wpad-openssl is not set
# CONFIG_DEFAULT_wpad-full-openssl is not set

# 不编译无线驱动/固件（真正让 WiFi 不工作）
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
# CONFIG_PACKAGE_kmod-ath11k-pci is not set
# CONFIG_PACKAGE_kmod-cfg80211 is not set
# CONFIG_PACKAGE_kmod-mac80211 is not set
# CONFIG_PACKAGE_ath11k-firmware-ipq6018 is not set
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set

# 360v6 的无线校准包也不要（避免链式拉起无线相关依赖）
# CONFIG_PACKAGE_ipq-wifi-qihoo_v6 is not set

# 可选：如果你不需要 LuCI 显示无线状态，也可禁用（不影响编译，只是更“纯有线”）
# CONFIG_PACKAGE_iwinfo is not set
# CONFIG_PACKAGE_rpcd-mod-iwinfo is not set

# 更彻底的纯有线：把 iwinfo 也禁掉（避免 LuCI 拉回无线信息组件）
# CONFIG_PACKAGE_iwinfo is not set
# CONFIG_PACKAGE_rpcd-mod-iwinfo is not set
# CONFIG_DEFAULT_iwinfo is not set
# CONFIG_DEFAULT_rpcd-mod-iwinfo is not set

# 可选：彻底禁掉无线工具
# CONFIG_PACKAGE_wireless-tools is not set
# CONFIG_DEFAULT_wireless-tools is not set
