### =========================
###  IPQ60XX / 360v6 / NOWIFI 最终版 .config
###  目标：只编译 qihoo_360v6，一个 profile；彻底不编译/不打包 WiFi 相关 userspace/驱动/固件
### =========================

##### 通用编译选项 #####
CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"
CONFIG_CCACHE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

# 语言（按你之前 generalconfig）
CONFIG_LUCI_LANG_zh_Hant=y

# 默认设置
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y

# 不用 initramfs
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

##### Target：只选 qualcommax/ipq60xx + 360v6 单机型 #####
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 关闭多 Profile，只编一个机型（关键）
# CONFIG_TARGET_MULTI_PROFILE is not set

# 只选 360v6
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y

##### 内存/NSS（保留你给的） #####
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_11_4=y

##### ZRAM（保留你给的） #####
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

##### 基础工具（保留你给的） #####
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_openssh-sftp-server=y

##### LuCI（保留必要项，按你 generalconfig） #####
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-app-watchcat=y

##### 精简不需要服务（按你 generalconfig） #####
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_ddns-scripts-cloudflare is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-sqm is not set

##### =========================
##### NOWIFI：彻底禁用 WiFi userspace + 默认包 + 驱动/固件
##### 目的：避免 hostapd/wpad 进入编译链，从根源规避 he_mu_edca 报错
##### =========================

# 不需要 11ax/11ac userspace/驱动编译开关
# CONFIG_DRIVER_11AX_SUPPORT is not set
# CONFIG_DRIVER_11AC_SUPPORT is not set
# CONFIG_WPA_ENABLE_IEEE80211AX is not set
# CONFIG_WPA_ENABLE_IEEE80211AC is not set
# CONFIG_WPA_ENABLE_IEEE80211BE is not set

# 禁用 hostapd / wpa_supplicant / wpad 全部变体
# CONFIG_PACKAGE_hostapd-common is not set
# CONFIG_PACKAGE_wpa-supplicant is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-openssl is not set
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_wpad-full-openssl is not set

# 禁用 WiFi 辅助包
# CONFIG_PACKAGE_wifi-scripts is not set
# CONFIG_PACKAGE_wireless-regdb is not set
# CONFIG_PACKAGE_iw is not set

# 关键：把“默认包”也禁掉（否则 make defconfig 可能会选回来）
# CONFIG_DEFAULT_hostapd-common is not set
# CONFIG_DEFAULT_wifi-scripts is not set
# CONFIG_DEFAULT_wireless-regdb is not set
# CONFIG_DEFAULT_wpad-basic-mbedtls is not set
# CONFIG_DEFAULT_wpad-mbedtls is not set
# CONFIG_DEFAULT_wpad-basic-openssl is not set
# CONFIG_DEFAULT_wpad-openssl is not set
# CONFIG_DEFAULT_wpad-full-openssl is not set

# 不编译无线驱动/固件（真正让 WiFi 不工作）
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
# CONFIG_PACKAGE_kmod-ath11k-pci is not set
# CONFIG_PACKAGE_kmod-cfg80211 is not set
# CONFIG_PACKAGE_kmod-mac80211 is not set
# CONFIG_PACKAGE_ath11k-firmware-ipq6018 is not set
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set

# 360v6 校准包也不要（避免被设备默认包链条拉起无线相关依赖）
# CONFIG_PACKAGE_ipq-wifi-qihoo_v6 is not set
